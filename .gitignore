# MCP server config (contains tokens)
.mcp.json

# CLAUDE.md backup during autonomous runs
CLAUDE.md.interactive

# Runner logs (session output, state, runner log)
expert-system/logs/

# Vault inner git repo (auto-managed by run-sessions.sh)
expert-system/vault/.git

# Cloned codebase (populated at runtime, 772MB)
expert-system/repos/

# Python cache
__pycache__/

# Secret files
.claude/settings.local.json
.claude/context/secrets/
.claude/context/gitlab-credentials.md
config/graylog/envs/secret.yaml

# Playwright MCP logs
.playwright-mcp/

# MCP tools swagger spec cache
.claude/mcp-tools/cache/

# Exploration artefacts (screenshots, PDFs, downloads)
expert-system/artefacts/

# Node modules (root and autotests)
node_modules/
autotests/node_modules/

# Autotest execution results (reports, screenshots, traces, videos)
autotests/playwright-report/
autotests/test-results/

# Test data run marker (temp file, not the YAML artifacts themselves)
autotests/test-data/.current-run-id

# Test execution history (JSON archives + matrix HTML)
autotests/history/

# JSON reporter intermediate output
autotests/test-results-json/
