%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#E8EDF2',
    'primaryTextColor': '#37474F',
    'primaryBorderColor': '#90A4AE',
    'lineColor': '#607D8B',
    'secondaryColor': '#F0F2F5',
    'background': '#FFFFFF',
    'mainBkg': '#E8EDF2',
    'nodeBorder': '#90A4AE',
    'clusterBkg': '#F5F7FA',
    'clusterBorder': '#B0BEC5',
    'titleColor': '#37474F',
    'edgeLabelBackground': '#FFFFFF',
    'fontSize': '15px'
  },
  'flowchart': {
    'curve': 'basis',
    'diagramPadding': 30,
    'rankSpacing': 55,
    'nodeSpacing': 25
  }
}}%%

graph TD
    SOURCES["<b>Information Sources</b><br/>GitLab Issues &bull; Codebase (Java/Spring + React/TS)<br/>Confluence &bull; Figma &bull; Qase &bull; PostgreSQL<br/>REST API (366 endpoints) &bull; Live UI (Playwright)"]

    subgraph PA["Phase A — Knowledge Acquisition"]
        direction LR
        INV["Autonomous<br/>Investigation"]
        VAULT["Obsidian Vault<br/>200+ Notes"]
        SQLITE["SQLite Analytics<br/>Findings &bull; Health"]
        INV --> VAULT
        INV --> SQLITE
    end

    subgraph PB["Phase B — Test Documentation"]
        direction LR
        ENRICH["Knowledge<br/>Enrichment"]
        GEN["XLSX Generator<br/>Python + openpyxl"]
        XLSX["Test Documentation<br/>Plans + Cases"]
        ENRICH --> GEN --> XLSX
    end

    subgraph PC["Phase C — Autotest Generation"]
        direction LR
        PARSE["XLSX Parser<br/>JSON Manifest"]
        CODEGEN["Code Generation<br/>Vault-Enriched"]
        VERIFY["Verify &<br/>Auto-Fix"]
        TESTS["Playwright E2E<br/>Specs + Pages + Data"]
        PARSE --> CODEGEN --> VERIFY --> TESTS
    end

    ORCH["<b>Session Orchestrator</b><br/>run-sessions.sh &bull; config.yaml &bull; Dashboard"]

    SOURCES ==> INV
    VAULT ==> ENRICH
    SQLITE ==> ENRICH
    XLSX ==> PARSE
    VAULT ==> CODEGEN
    TESTS -.->|"write-back"| VAULT
    ORCH -.->|"orchestrates all phases"| PA

    classDef sourceBox fill:#E3EBF3,stroke:#78909C,color:#263238,stroke-width:2px
    classDef phaseANode fill:#E0EAF0,stroke:#78909C,color:#37474F,stroke-width:1.5px
    classDef phaseBNode fill:#EDE8E2,stroke:#A1887F,color:#37474F,stroke-width:1.5px
    classDef phaseCNode fill:#E3E0EB,stroke:#9E9E9E,color:#37474F,stroke-width:1.5px
    classDef storageNode fill:#F5F0E0,stroke:#BCAA8C,color:#37474F,stroke-width:1.5px
    classDef orchNode fill:#ECEFF1,stroke:#90A4AE,color:#37474F,stroke-width:1.5px

    class SOURCES sourceBox
    class INV phaseANode
    class VAULT,SQLITE storageNode
    class ENRICH,GEN phaseBNode
    class XLSX storageNode
    class PARSE,CODEGEN,VERIFY phaseCNode
    class TESTS storageNode
    class ORCH orchNode

    linkStyle default stroke:#607D8B,stroke-width:2px
