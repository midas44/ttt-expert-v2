%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#E8EDF2',
    'primaryTextColor': '#37474F',
    'primaryBorderColor': '#90A4AE',
    'lineColor': '#607D8B',
    'background': '#FFFFFF',
    'mainBkg': '#E8EDF2',
    'nodeBorder': '#90A4AE',
    'clusterBkg': '#F5F7FA',
    'clusterBorder': '#B0BEC5',
    'titleColor': '#37474F',
    'edgeLabelBackground': '#FFFFFF',
    'fontSize': '16px'
  },
  'flowchart': {
    'curve': 'basis',
    'diagramPadding': 25,
    'rankSpacing': 55,
    'nodeSpacing': 18,
    'padding': 20
  }
}}%%

graph LR
    subgraph AGENT["&ensp; Agent &ensp;"]
        direction TB
        A1["<b>System Prompt</b><br/>CLAUDE+.md"]
        A2["<b>20 Skills</b><br/>GitLab &bull; Swagger<br/>Playwright &bull; ..."]
        A3["<b>config.yaml</b><br/>Phase &bull; Scope"]
    end

    subgraph MCP["&ensp; Integration Layer — 39 MCP Servers + 2 Skill-Only &ensp;"]
        direction TB
        subgraph MCP_K["&ensp; Knowledge Base &ensp;"]
            K1["Obsidian"]
            K2["QMD Search"]
            K3["SQLite"]
        end
        subgraph MCP_L["&ensp; Live Environments &ensp;"]
            L1["PostgreSQL x3"]
            L2["Swagger x21"]
            L3["Playwright<br/>TTT + CS + PMT"]
        end
        subgraph MCP_E["&ensp; External Sources &ensp;"]
            E1["Confluence"]
            E2["Figma"]
            E3["Qase"]
            E4["GitLab"]
            E5["Roundcube"]
            E6["Graylog"]
        end
    end

    subgraph OUT["&ensp; Generated Artifacts &ensp;"]
        direction TB
        O1["<b>Knowledge Base</b><br/>Obsidian Vault"]
        O2["<b>Test Docs</b><br/>XLSX Workbooks"]
        O3["<b>E2E Tests</b><br/>Playwright + TS"]
        O4["<b>Dashboard</b>"]
    end

    AGENT ==> MCP ==> OUT
    O3 -.->|"write-back"| K1

    classDef agentNode fill:#DAE3ED,stroke:#78909C,color:#263238,stroke-width:2px
    classDef mcpNode fill:#E8EDF2,stroke:#90A4AE,color:#37474F,stroke-width:1.5px
    classDef outNode fill:#E0E8E5,stroke:#81A594,color:#263238,stroke-width:2px

    class A1,A2,A3 agentNode
    class K1,K2,K3,L1,L2,L3,E1,E2,E3,E4,E5,E6 mcpNode
    class O1,O2,O3,O4 outNode

    linkStyle default stroke:#607D8B,stroke-width:2.5px
