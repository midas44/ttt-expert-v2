%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#E8EDF2',
    'primaryTextColor': '#37474F',
    'primaryBorderColor': '#90A4AE',
    'lineColor': '#607D8B',
    'background': '#FFFFFF',
    'mainBkg': '#E8EDF2',
    'nodeBorder': '#90A4AE',
    'clusterBkg': '#F5F7FA',
    'clusterBorder': '#B0BEC5',
    'titleColor': '#37474F',
    'edgeLabelBackground': '#FFFFFF',
    'fontSize': '16px'
  },
  'flowchart': {
    'curve': 'basis',
    'diagramPadding': 15,
    'rankSpacing': 50,
    'nodeSpacing': 12,
    'padding': 10
  }
}}%%

graph LR
    subgraph AGENT["Agent"]
        direction TB
        A1["<b>System Prompt</b><br/>CLAUDE+.md / CLAUDE.md"]
        A2["<b>17 Skills</b><br/>GitLab &bull; Swagger<br/>Playwright &bull; Autotest<br/>Gen/Run/Fix &bull; ..."]
        A3["<b>config.yaml</b><br/>Phase &bull; Scope<br/>Autonomy"]
    end

    subgraph MCP["MCP Integration Layer — 39 Servers"]
        direction TB
        subgraph MCP_K["Knowledge"]
            K1["<b>Obsidian</b><br/>Vault CRUD"]
            K2["<b>QMD</b><br/>Semantic Search"]
            K3["<b>SQLite</b><br/>Analytics DB"]
        end
        subgraph MCP_L["Live Environments"]
            L1["<b>PostgreSQL</b><br/>3 environments"]
            L2["<b>Swagger API</b><br/>21 instances"]
            L3["<b>Playwright</b><br/>Browser"]
        end
        subgraph MCP_E["External Sources"]
            E1["<b>Confluence</b><br/>Requirements"]
            E2["<b>Figma</b><br/>Designs"]
            E3["<b>Qase</b><br/>Test Suites"]
            E4["<b>GitLab</b><br/>Issues &bull; Code"]
        end
    end

    subgraph OUT["Generated Artifacts"]
        direction TB
        O1["<b>Knowledge Base</b><br/>Obsidian Vault<br/>200+ Notes"]
        O2["<b>Test Documentation</b><br/>XLSX Workbooks<br/>per Module / Ticket"]
        O3["<b>E2E Test Suite</b><br/>Playwright + TypeScript<br/>Specs + Pages + Data"]
        O4["<b>Analytics Dashboard</b><br/>Coverage &bull; Health<br/>Progress Metrics"]
    end

    AGENT ==> MCP ==> OUT
    O3 -.->|"findings write-back"| K1

    classDef agentNode fill:#DAE3ED,stroke:#78909C,color:#263238,stroke-width:2px
    classDef mcpNode fill:#E8EDF2,stroke:#90A4AE,color:#37474F,stroke-width:1.5px
    classDef outNode fill:#E0E8E5,stroke:#81A594,color:#263238,stroke-width:2px

    class A1,A2,A3 agentNode
    class K1,K2,K3,L1,L2,L3,E1,E2,E3,E4 mcpNode
    class O1,O2,O3,O4 outNode

    linkStyle default stroke:#607D8B,stroke-width:2.5px
